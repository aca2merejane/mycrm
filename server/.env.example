# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:9000

# Database Configuration (Remote MySQL)
DB_HOST=your_remote_host
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=mycrm

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# Custom WA-API Integration
WA_API_URL=your_custom_wa_api_url
WA_API_KEY=your_wa_api_key
